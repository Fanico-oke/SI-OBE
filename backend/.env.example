# ==============================================
#  SI-OBE Backend — Environment Variables
# ==============================================
# Copy file ini menjadi .env dan isi semua value

# Database connection string (MySQL)
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://root:@localhost:3306/siobe_db"

# Server Port
PORT=5000

# JWT Secret — WAJIB! String acak minimal 64 karakter
# Generate dengan: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# Environment: development / production
NODE_ENV=development

# CORS Origin — domain frontend di production
# Kosongkan untuk development (mengizinkan semua origin)
# Contoh: https://si-obe.example.com
# CORS_ORIGIN=
